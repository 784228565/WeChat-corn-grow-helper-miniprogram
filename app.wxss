/* The Living Ledger - Global Styles */
page {
  --primary: #154212;
  --secondary: #376B10;
  --background: #fbf9f5;
  --surface: #fbf9f5;
  --surface-bright: #fbf9f5;
  --surface-container: #efeeea;
  --surface-container-low: #f5f3ef;
  --surface-container-high: #eae8e4;
  --surface-container-lowest: #ffffff;
  --surface-dim: #dbdad6;
  --surface-variant: #e4e2de;
  --primary-container: #2d5a27;
  --secondary-container: #b6f48a;
  --primary-fixed: #bcf0ae;
  --secondary-fixed: #b6f48a;
  --secondary-fixed-dim: #9bd771;
  --on-primary: #ffffff;
  --on-secondary: #ffffff;
  --on-surface: #1b1c1a;
  --on-surface-variant: #42493e;
  --on-background: #1b1c1a;
  --on-primary-container: #9dd090;
  --on-secondary-container: #3d7117;
  --outline: #72796e;
  --outline-variant: #c2c9bb;
  --error: #ba1a1a;

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  background-color: var(--background);
  color: var(--on-surface);
  -webkit-font-smoothing: antialiased;
}

/* Typography */
.font-headline {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-weight: 700;
}

.font-body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-weight: 400;
}

.font-label {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-weight: 500;
}

/* Common Components */
.glass-panel {
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.card {
  background-color: var(--surface-container-low);
  border-radius: 32rpx;
}

.btn-primary {
  background: linear-gradient(135deg, var(--secondary), var(--secondary-fixed-dim));
  color: var(--on-secondary);
  border-radius: 16rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-secondary {
  background-color: var(--surface-container-low);
  color: var(--primary);
  border-radius: 16rpx;
  font-weight: 600;
}

/* No line rule - use background shifts instead of borders */
.no-border {
  border: none;
}

/* Hide scrollbar */
.scrollbar-hide::-webkit-scrollbar {
  display: none;
}
.scrollbar-hide {
  scrollbar-width: none;
}

/* Safe area padding for bottom nav */
.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
