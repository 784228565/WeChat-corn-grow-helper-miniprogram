/* Logs Page Styles - Matching _1/screen.png */
.container {
  min-height: 100vh;
  background-color: var(--surface);
  padding-bottom: 200rpx;
}

/* App Bar */
.app-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 48rpx 32rpx 24rpx;
  background-color: var(--surface);
}

.app-bar-left {
  display: flex;
  align-items: center;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  background-color: var(--surface-container-high);
}

.avatar-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.avatar-fallback {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background-color: #e8e8e8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.app-title {
  font-size: 32rpx;
  font-weight: 900;
  color: var(--primary);
  text-transform: uppercase;
  letter-spacing: 2rpx;
  text-align: center;
  flex: 1;
}

.app-bar-right {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}

.notification-icon {
  font-size: 40rpx;
}

/* Content */
.content {
  padding: 32rpx;
}

/* Page Header */
.page-header {
  margin-bottom: 64rpx;
  padding-left: 16rpx;
  border-left: 8rpx solid var(--secondary-fixed);
}

.page-title {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  color: var(--primary);
  line-height: 1.15;
}

.page-subtitle {
  display: block;
  font-size: 30rpx;
  color: var(--on-surface-variant);
  margin-top: 12rpx;
}

/* Logs List */
.logs-list {
  display: flex;
  flex-direction: column;
  gap: 64rpx;
}

/* Log Card */
.log-card {
  background-color: var(--surface-container-low);
  border-radius: 32rpx;
  padding: 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(21, 66, 18, 0.04);
  position: relative;
  overflow: hidden;
}

.log-decoration {
  position: absolute;
  top: 0;
  right: 0;
  width: 256rpx;
  height: 256rpx;
  background-color: var(--primary-fixed);
  opacity: 0.2;
  border-bottom-left-radius: 100%;
  margin-right: -64rpx;
  margin-top: -64rpx;
}

.log-content {
  position: relative;
  z-index: 1;
}

.log-main {
  display: flex;
  flex-direction: column;
  gap: 48rpx;
}

.log-meta {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.stage-badge {
  display: inline-flex;
  align-self: flex-start;
  background-color: var(--primary-fixed);
  border-radius: 9999rpx;
  padding: 12rpx 32rpx;
}

.vegetative-badge {
  background-color: var(--secondary-fixed);
}

.stage-badge-text {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--on-primary-fixed);
  text-transform: uppercase;
  letter-spacing: 4rpx;
}

.vegetative-badge .stage-badge-text {
  color: var(--on-secondary-fixed);
}

.log-stage-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--primary);
  margin-top: 16rpx;
}

.log-date {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 8rpx;
}

.date-icon {
  font-size: 28rpx;
}

.date-text {
  font-size: 26rpx;
  color: var(--on-surface-variant);
}

.log-details {
  display: flex;
  flex-direction: column;
  gap: 48rpx;
}

.tasks-box {
  background-color: var(--surface);
  border-radius: 32rpx;
  padding: 48rpx;
  box-shadow: 0 4rpx 16rpx rgba(21, 66, 18, 0.02);
}

.tasks-box-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.tasks-box-icon {
  font-size: 36rpx;
  color: var(--secondary);
}

.tasks-box-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--primary);
}

.tasks-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.task-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.task-check {
  font-size: 32rpx;
  margin-top: 4rpx;
  flex-shrink: 0;
}

.task-text {
  font-size: 28rpx;
  color: var(--on-surface);
  line-height: 1.5;
}

/* Photos Grid */
.photos-grid {
  display: flex;
  gap: 24rpx;
  flex-wrap: wrap;
}

.log-photo {
  width: 256rpx;
  height: 256rpx;
  border-radius: 32rpx;
  object-fit: cover;
}

.photo-placeholder {
  width: 256rpx;
  height: 256rpx;
  background-color: var(--surface-container);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  font-size: 48rpx;
  color: var(--secondary);
}

/* Bottom Navigation */
.bottom-nav {
  position: fixed;
  bottom: 48rpx;
  left: 5%;
  width: 90%;
  max-width: 640rpx;
  border-radius: 9999rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(21, 66, 18, 0.08);
  z-index: 50;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 32rpx;
  border-radius: 9999rpx;
  opacity: 0.6;
}

.active-nav-item {
  background-color: var(--primary-container);
  opacity: 1;
}

.nav-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.nav-label {
  font-size: 20rpx;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 4rpx;
  color: var(--primary);
}

.active-nav-label {
  color: var(--secondary-container);
}
