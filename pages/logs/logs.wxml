<view class="container">
  <!-- Top App Bar -->
  <view class="app-bar">
    <view class="app-bar-left">
      <view class="avatar">
        <image wx:if="{{avatarUrl}}" class="avatar-img" src="{{avatarUrl}}" mode="aspectFill" binderror="onAvatarError" />
        <view wx:else class="avatar-fallback">👤</view>
      </view>
    </view>
    <text class="app-title">农田管家</text>
    <view class="app-bar-right">
      <text class="notification-icon">🔔</text>
    </view>
  </view>

  <view class="content">
    <!-- Page Header -->
    <view class="page-header">
      <text class="page-title">打卡记录</text>
      <text class="page-subtitle">您的种植管理历史记录。</text>
    </view>

    <!-- Loading State -->
    <view class="loading-state" wx:if="{{loading && logs.length === 0}}">
      <text class="loading-text">加载记录中...</text>
    </view>

    <!-- Empty State -->
    <view class="empty-state" wx:if="{{!loading && logs.length === 0}}">
      <text class="empty-icon">📋</text>
      <text class="empty-title">暂无打卡记录</text>
      <text class="empty-desc">完成每日任务并打卡，开始记录您的种植历程。</text>
      <view class="btn-primary" bindtap="navigateTo" data-page="checkin">
        <text>去打卡</text>
      </view>
    </view>

    <!-- Logs List -->
    <view class="logs-list" wx:if="{{logs.length > 0}}">
      <view class="log-card" wx:for="{{logs}}" wx:key="id" bindtap="viewDetail" data-id="{{item.id}}">
        <view class="log-decoration"></view>
        <view class="log-content">
          <view class="log-main">
            <view class="log-meta">
              <view class="stage-badge">
                <text class="stage-badge-text">{{item.stage}} - {{item.stageLabel}}</text>
              </view>
              <view class="log-date">
                <text class="date-icon">📅</text>
                <text class="date-text">{{item.dateText}}</text>
              </view>
            </view>
            <view class="log-summary">
              <text class="summary-text">已完成 {{item.completedTaskCount}}/{{item.totalTaskCount}} 项任务</text>
              <text class="summary-location" wx:if="{{item.location}}">📍 {{item.location}}</text>
            </view>
            <view class="log-thumbnail" wx:if="{{item.thumbnail}}">
              <image class="thumb-img" src="{{item.thumbnail}}" mode="aspectFill" />
            </view>
          </view>
        </view>
      </view>

      <!-- Load More -->
      <view class="load-more" wx:if="{{hasMore}}" bindtap="loadMore">
        <text class="load-more-text">加载更多</text>
      </view>
    </view>
  </view>

  <!-- Bottom Navigation -->
  <view class="bottom-nav glass-panel">
    <view class="nav-item" bindtap="navigateTo" data-page="checkin">
      <text class="nav-icon">🚜</text>
      <text class="nav-label">打卡</text>
    </view>
    <view class="nav-item active-nav-item" bindtap="navigateTo" data-page="logs">
      <text class="nav-icon">⏱</text>
      <text class="nav-label active-nav-label">记录</text>
    </view>
    <view class="nav-item" bindtap="navigateTo" data-page="ai">
      <text class="nav-icon">🤖</text>
      <text class="nav-label">AI助手</text>
    </view>
  </view>
</view>
