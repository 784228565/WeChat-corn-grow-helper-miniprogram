/* Check-in Page Styles - Matching _2/screen.png */
.container {
  min-height: 100vh;
  background-color: var(--surface);
  padding-bottom: 200rpx;
}

/* App Bar */
.app-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 48rpx 32rpx 24rpx;
  background-color: var(--surface);
  position: sticky;
  top: 0;
  z-index: 70;
}

.app-bar-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  background-color: var(--surface-container-high);
}

.avatar-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.avatar-fallback {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background-color: #e8e8e8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.app-title {
  font-size: 32rpx;
  font-weight: 900;
  color: var(--primary);
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.app-bar-right {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: var(--surface-container-lowest);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(21, 66, 18, 0.04);
}

.notification-icon {
  font-size: 36rpx;
}

/* Farm Menu Dropdown */
.farm-menu {
  position: absolute;
  top: 128rpx;
  left: 32rpx;
  width: 520rpx;
  background-color: var(--surface-container-lowest);
  border-radius: 32rpx;
  box-shadow: 0 16rpx 64rpx rgba(21, 66, 18, 0.12);
  padding: 32rpx;
  z-index: 60;
  opacity: 0;
  transform: translateY(-20rpx);
  pointer-events: none;
  transition: all 0.25s ease;
}

.farm-menu-show {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

.farm-menu-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(219, 218, 214, 0.3);
}

.farm-menu-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--primary);
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.farm-menu-close {
  font-size: 28rpx;
  color: var(--outline);
  padding: 8rpx 16rpx;
}

.farm-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.farm-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  transition: background-color 0.2s;
}

.farm-item:active {
  background-color: var(--surface-container-low);
}

.farm-item-active {
  background-color: var(--primary-fixed);
}

.farm-icon {
  font-size: 40rpx;
}

.farm-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.farm-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--on-surface);
}

.farm-location {
  font-size: 22rpx;
  color: var(--on-surface-variant);
  margin-top: 4rpx;
}

.farm-check {
  font-size: 28rpx;
  color: var(--secondary);
  font-weight: 700;
}

.farm-add {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  border: 2rpx dashed var(--outline-variant);
  background-color: var(--surface-container-low);
}

.farm-add:active {
  background-color: var(--surface-container-high);
}

.farm-add-icon {
  font-size: 32rpx;
  color: var(--secondary);
  font-weight: 700;
}

.farm-add-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary);
}

/* Menu Overlay */
.menu-overlay {
  position: fixed;
  inset: 0;
  background-color: rgba(27, 28, 26, 0.2);
  z-index: 50;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.25s ease;
}

.menu-overlay-show {
  opacity: 1;
  pointer-events: auto;
}

/* Content */
.content {
  padding: 32rpx;
}

/* Page Header */
.page-header {
  margin-bottom: 48rpx;
}

.page-title-group {
  margin-bottom: 32rpx;
  padding-left: 16rpx;
}

.page-title {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  color: var(--primary);
  line-height: 1.15;
  margin-bottom: 12rpx;
}

.page-subtitle {
  display: block;
  font-size: 30rpx;
  color: var(--on-surface-variant);
}

.progress-card {
  background-color: var(--surface-container-lowest);
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(21, 66, 18, 0.04);
}

.progress-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.progress-label,
.progress-stage {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--primary);
}

.progress-bar-bg {
  width: 100%;
  height: 16rpx;
  background-color: var(--surface-container);
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background-color: var(--secondary);
  border-radius: 8rpx;
}

/* Timeline */
.timeline-scroll {
  width: 100%;
  margin-bottom: 8rpx;
  padding-left: 16rpx;
}

.timeline {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: max-content;
  padding: 24rpx 0;
}

.timeline-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.timeline-item.active {
  transform: scale(1.1);
}

.timeline-dot {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.completed-dot {
  background-color: var(--primary-fixed);
}

.active-dot {
  width: 128rpx;
  height: 128rpx;
  background-color: var(--secondary);
  box-shadow: 0 8rpx 32rpx rgba(55, 107, 16, 0.2);
}

.upcoming-dot {
  background-color: var(--surface-container);
}

.checkable-dot {
  background-color: #4CAF50;
  box-shadow: 0 4rpx 16rpx rgba(76, 175, 80, 0.3);
}

.expired-dot {
  background-color: #FF9800;
  box-shadow: 0 4rpx 16rpx rgba(255, 152, 0, 0.3);
}

.timeline-check {
  font-size: 40rpx;
  color: var(--on-primary-fixed);
  font-weight: 700;
}

.timeline-flower {
  font-size: 48rpx;
}

.timeline-eco {
  font-size: 40rpx;
  color: var(--on-surface-variant);
}

.timeline-label {
  font-size: 26rpx;
  font-weight: 700;
}

.completed-label {
  color: var(--primary);
}

.active-label {
  color: var(--secondary);
}

.upcoming-label {
  color: var(--on-surface-variant);
}

.checkable-label {
  color: #4CAF50;
}

.expired-label {
  color: #FF9800;
}

.timeline-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-bottom: 48rpx;
  padding: 0 32rpx;
}

.timeline-hint-icon {
  font-size: 24rpx;
  color: var(--on-surface-variant);
  opacity: 0.55;
}

.timeline-hint-text {
  font-size: 22rpx;
  color: var(--on-surface-variant);
  opacity: 0.55;
}

.timeline-line {
  width: 64rpx;
  height: 8rpx;
  border-radius: 4rpx;
}

.completed-line {
  background-color: var(--primary-fixed);
}

.upcoming-line {
  background-color: var(--surface-container-high);
}

/* Main Grid */
.main-grid {
  display: flex;
  flex-direction: column;
  gap: 48rpx;
}

/* Stage Card */
.stage-card {
  background-color: var(--surface-container-lowest);
  border-radius: 32rpx;
  padding: 64rpx;
  box-shadow: 0 8rpx 32rpx rgba(21, 66, 18, 0.06);
  position: relative;
  overflow: hidden;
}

.stage-card::before {
  content: '';
  position: absolute;
  top: -160rpx;
  right: -160rpx;
  width: 512rpx;
  height: 512rpx;
  background-color: var(--secondary-container);
  border-radius: 50%;
  opacity: 0.2;
  filter: blur(80rpx);
}

.stage-card-header {
  display: flex;
  align-items: center;
  gap: 32rpx;
  margin-bottom: 48rpx;
  position: relative;
  z-index: 1;
}

.stage-icon-wrapper {
  width: 96rpx;
  height: 96rpx;
  background-color: var(--primary-fixed);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.stage-icon {
  font-size: 48rpx;
}

.stage-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary);
}

.stage-subtitle {
  display: block;
  font-size: 24rpx;
  color: var(--on-surface-variant);
  margin-top: 8rpx;
}

.stage-status-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 8rpx;
  margin-bottom: 4rpx;
}

.stage-status-badge {
  display: inline-block;
  font-size: 22rpx;
  font-weight: 700;
  padding: 4rpx 16rpx;
  border-radius: 9999rpx;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.stage-status-readable {
  background-color: var(--surface-container-high);
  color: var(--on-surface-variant);
}

.stage-status-checkable {
  background-color: rgba(76, 175, 80, 0.15);
  color: #2E7D32;
}

.stage-status-expired {
  background-color: rgba(255, 152, 0, 0.15);
  color: #E65100;
}

.stage-date {
  font-size: 22rpx;
  color: var(--on-surface-variant);
}

.stage-description {
  display: block;
  font-size: 30rpx;
  color: var(--on-surface);
  line-height: 1.6;
  margin-bottom: 48rpx;
  position: relative;
  z-index: 1;
}

.stage-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  justify-content: center;
  margin-bottom: 48rpx;
  position: relative;
  z-index: 1;
}

.btn-upload {
  background-color: var(--secondary);
  color: var(--on-secondary);
  border-radius: 16rpx;
  padding: 24rpx 40rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-weight: 700;
  box-shadow: 0 4rpx 16rpx rgba(21, 66, 18, 0.08);
}

.btn-upload-icon {
  font-size: 32rpx;
}

.btn-upload-text {
  font-size: 28rpx;
}

.btn-video {
  background-color: var(--surface-container-low);
  color: var(--primary);
  border-radius: 16rpx;
  padding: 24rpx 40rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-weight: 600;
  border: 1rpx solid rgba(194, 201, 187, 0.15);
}

.btn-video-icon {
  font-size: 32rpx;
}

.btn-video-text {
  font-size: 28rpx;
}

/* Subscribe button */
.subscribe-row {
  margin-bottom: 32rpx;
  display: flex;
  justify-content: center;
}

.btn-subscribe {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  color: var(--secondary);
  border-radius: 16rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: 700;
  border: 2rpx solid var(--secondary);
  box-shadow: 0 4rpx 16rpx rgba(55, 107, 16, 0.08);
}

.btn-subscribe-icon {
  font-size: 32rpx;
}

.btn-subscribe-text {
  font-size: 28rpx;
}

.plan-summary {
  background: linear-gradient(135deg, #FFF8E1, #FFECB3);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border-left: 6rpx solid #F57C00;
}

.plan-summary-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.plan-summary-icon {
  font-size: 32rpx;
}

.plan-summary-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #E65100;
}

.plan-summary-body {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.plan-summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.plan-summary-label {
  font-size: 26rpx;
  color: #BF360C;
  font-weight: 600;
}

.plan-summary-value {
  font-size: 26rpx;
  color: #E65100;
  font-weight: 700;
  text-align: right;
  flex: 1;
  margin-left: 16rpx;
}

.plan-summary-ref {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 2rpx dashed rgba(245, 124, 0, 0.3);
  font-size: 24rpx;
  color: #E65100;
  line-height: 1.5;
  font-weight: 500;
}

.plan-summary-note {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #BF360C;
  line-height: 1.5;
}

.plan-missing {
  background: linear-gradient(135deg, #FFEBEE, #FFCDD2);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border-left: 6rpx solid #C62828;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 16rpx;
}

.plan-missing-icon {
  font-size: 48rpx;
}

.plan-missing-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #B71C1C;
}

.plan-missing-body {
  font-size: 26rpx;
  color: #C62828;
  line-height: 1.6;
}

.plan-missing-action {
  margin-top: 8rpx;
  background: linear-gradient(135deg, #EF5350, #C62828);
  color: #fff;
  border-radius: 32rpx;
  padding: 20rpx 48rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.stage-description {
  background: linear-gradient(135deg, #E3F2FD, #BBDEFB);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border-left: 6rpx solid #1976D2;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.stage-desc-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0D47A1;
}

.stage-desc-body {
  font-size: 26rpx;
  color: #1565C0;
  line-height: 1.6;
  font-weight: 500;
}

/* Side Column */
.side-column {
  display: flex;
  flex-direction: column;
  gap: 48rpx;
}

/* Tasks Card */
.tasks-card {
  background-color: var(--surface-container-low);
  border-radius: 32rpx;
  padding: 48rpx;
}

.tasks-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 48rpx;
}

.tasks-icon {
  font-size: 36rpx;
  color: var(--secondary);
}

.tasks-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary);
}

.task-list {
  display: flex;
  flex-direction: column;
}

.task-item {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  padding: 32rpx 0;
  border-bottom: 1rpx solid rgba(219, 218, 214, 0.3);
}

.task-item:last-child {
  border-bottom: none;
}

.task-checkbox {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 4rpx solid var(--outline);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.task-checkbox.checked {
  background-color: var(--secondary);
  border-color: var(--secondary);
}

.task-checkmark {
  font-size: 24rpx;
  color: var(--on-secondary);
  font-weight: 700;
}

.task-content {
  flex: 1;
}

.task-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--primary);
}

.completed-name {
  text-decoration: line-through;
  opacity: 0.7;
}

.task-meta {
  display: block;
  font-size: 24rpx;
  color: var(--on-surface-variant);
  margin-top: 8rpx;
}

/* Check-in Button */
.checkin-action {
  margin-top: 48rpx;
  padding-top: 32rpx;
  border-top: 1rpx solid rgba(219, 218, 214, 0.3);
}

.btn-checkin {
  background: linear-gradient(135deg, var(--secondary), var(--secondary-fixed-dim));
  color: var(--on-secondary);
  border-radius: 32rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 32rpx rgba(55, 107, 16, 0.15);
  transition: all 0.2s;
}

.btn-checkin:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(55, 107, 16, 0.2);
}

.btn-checked {
  background: linear-gradient(135deg, var(--primary-container), var(--primary));
  box-shadow: 0 8rpx 32rpx rgba(21, 66, 18, 0.12);
}

.btn-checkin.btn-disabled {
  background: linear-gradient(135deg, #BDBDBD, #9E9E9E);
  box-shadow: none;
  opacity: 0.7;
}

.btn-checkin-icon {
  font-size: 36rpx;
}

.btn-checkin-text {
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

/* Insight Card */
.insight-card {
  background-color: var(--surface-bright);
  border-radius: 32rpx;
  padding: 48rpx;
  position: relative;
  overflow: hidden;
}

.insight-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.insight-icon {
  font-size: 32rpx;
  color: var(--secondary);
}

.insight-label {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--secondary);
  text-transform: uppercase;
  letter-spacing: 4rpx;
}

.insight-text {
  font-size: 28rpx;
  color: var(--on-surface-variant);
  line-height: 1.6;
}

.insight-highlight {
  font-weight: 700;
  color: var(--primary);
}

/* Bottom Navigation */
.bottom-nav {
  position: fixed;
  bottom: 48rpx;
  left: 5%;
  width: 90%;
  max-width: 640rpx;
  border-radius: 9999rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(21, 66, 18, 0.08);
  z-index: 50;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 32rpx;
  border-radius: 9999rpx;
}

.nav-item:first-child {
  background-color: var(--primary-container);
}

.nav-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.nav-label {
  font-size: 20rpx;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 4rpx;
  color: var(--primary);
}

.nav-item:first-child .nav-label {
  color: var(--secondary-container);
}
