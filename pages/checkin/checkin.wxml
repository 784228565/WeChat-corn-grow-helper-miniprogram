<view class="container">
  <!-- Top App Bar -->
  <view class="app-bar">
    <view class="app-bar-left">
      <view class="avatar" bindtap="toggleFarmMenu">
        <image wx:if="{{avatarUrl}}" class="avatar-img" src="{{avatarUrl}}" mode="aspectFill" binderror="onAvatarError" />
        <view wx:else class="avatar-fallback">👤</view>
      </view>
      <text class="app-title">农田管家</text>
    </view>
    <view class="app-bar-right">
      <text class="notification-icon">🔔</text>
    </view>

    <!-- Farm Switch Dropdown -->
    <view class="farm-menu {{showFarmMenu ? 'farm-menu-show' : ''}}">
      <view class="farm-menu-header">
        <text class="farm-menu-title">您的农场</text>
        <text class="farm-menu-close" bindtap="closeFarmMenu">✕</text>
      </view>
      <view class="farm-list">
        <view 
          class="farm-item {{item.isActive ? 'farm-item-active' : ''}}" 
          wx:for="{{farms}}" 
          wx:key="farmId"
          bindtap="selectFarm"
          data-farmid="{{item.farmId}}"
        >
          <view class="farm-icon">{{item.isActive ? '🌽' : '🌾'}}</view>
          <view class="farm-info">
            <text class="farm-name">{{item.name}}</text>
            <text class="farm-location">{{item.location}}</text>
          </view>
          <text class="farm-check" wx:if="{{item.isActive}}">✓</text>
        </view>
      </view>
      <view class="farm-add" bindtap="addNewFarm">
        <text class="farm-add-icon">+</text>
        <text class="farm-add-text">添加新农场</text>
      </view>
    </view>
  </view>

  <!-- Overlay -->
  <view class="menu-overlay {{showFarmMenu ? 'menu-overlay-show' : ''}}" bindtap="closeFarmMenu"></view>

  <!-- Loading State -->
  <view class="loading-state" wx:if="{{loading}}">
    <text class="loading-text">加载农场中...</text>
  </view>

  <!-- Empty State (no farms) -->
  <view class="empty-state" wx:if="{{!loading && !hasFarms}}">
    <text class="empty-icon">🏡</text>
    <text class="empty-title">暂无农场</text>
    <text class="empty-desc">创建第一个农场开始管理。</text>
    <view class="btn-primary" bindtap="addNewFarm">
      <text>创建农场</text>
    </view>
  </view>

  <!-- Empty State (has farm but no calendar matched) -->
  <view class="empty-state" wx:if="{{!loading && hasFarms && nodes.length === 0}}">
    <text class="empty-icon">📋</text>
    <text class="empty-title">无法生成种植方案</text>
    <text class="empty-desc">当前农场条件无法匹配到种植方案，请检查积温、土地类型和灌溉方式。</text>
    <view class="btn-primary" bindtap="addNewFarm">
      <text>完善农场信息</text>
    </view>
  </view>

  <!-- Main Content -->
  <view class="content" wx:if="{{!loading && hasFarms && nodes.length > 0}}">
    <!-- Header Section -->
    <view class="page-header">
      <view class="page-title-group">
        <text class="page-title">当前作物：{{cropName}}</text>
      </view>
      <view class="progress-card">
        <view class="progress-header">
          <text class="progress-label">第 {{currentNodeIndex + 1}} / {{totalNodes}} 节点</text>
          <text class="progress-stage">{{currentNode.title}}</text>
        </view>
        <view class="progress-bar-bg">
          <view class="progress-bar-fill" style="width: {{totalNodes > 0 ? ((currentNodeIndex + 1) / totalNodes) * 100 : 0}}%"></view>
        </view>
      </view>
    </view>

    <!-- Timeline -->
    <scroll-view class="timeline-scroll" scroll-x="true" show-scrollbar="false">
      <view class="timeline">
        <view class="timeline-item {{item.itemClass}}" 
              wx:for="{{nodeDisplayClasses}}" 
              wx:key="nodeIndex"
              bindtap="onSelectNode"
              data-index="{{index}}">
          <view class="timeline-dot {{item.dotClass}}">
            <text class="timeline-check">{{item.icon}}</text>
          </view>
          <text class="timeline-label {{item.labelClass}}">{{item.nodeIndex}}</text>
          <view class="timeline-line {{item.lineClass}}" wx:if="{{item.hasLine}}"></view>
        </view>
      </view>
    </scroll-view>
    <view class="timeline-hint">
      <text class="timeline-hint-icon">↔</text>
      <text class="timeline-hint-text">左右滑动查看更多节点</text>
    </view>

    <!-- Main Content Grid -->
    <view class="main-grid">
      <!-- Current Node Card -->
      <view class="stage-card">
        <view class="stage-card-header">
          <view class="stage-icon-wrapper">
            <text class="stage-icon">🌾</text>
          </view>
          <view class="stage-title-group">
            <text class="stage-title">{{currentNode.title}}</text>
            <view class="stage-status-row">
              <text class="stage-status-badge stage-status-{{nodeStatus}}">{{nodeStatusText}}</text>
              <text class="stage-date">{{currentNode.date}}</text>
            </view>
            <text class="stage-subtitle" wx:if="{{!loadingDetail}}">{{currentNode.reason || '正在加载节点信息...'}}</text>
            <text class="stage-subtitle" wx:if="{{loadingDetail}}">加载详情中...</text>
          </view>
        </view>
        <!-- 方案摘要：展示用户农场实际信息 -->
        <view class="plan-summary" wx:if="{{!loadingDetail && planScenario}}">
          <view class="plan-summary-header">
            <text class="plan-summary-icon">📋</text>
            <text class="plan-summary-title">当前方案</text>
          </view>
          <view class="plan-summary-body">
            <view class="plan-summary-row">
              <text class="plan-summary-label">积温</text>
              <text class="plan-summary-value">{{planScenario.accumulatedTemp}}℃</text>
            </view>
            <view class="plan-summary-row">
              <text class="plan-summary-label">土地</text>
              <text class="plan-summary-value">{{planScenario.soilType}}</text>
            </view>
            <view class="plan-summary-row">
              <text class="plan-summary-label">灌溉</text>
              <text class="plan-summary-value">{{planScenario.irrigation}}</text>
            </view>
            <view class="plan-summary-row">
              <text class="plan-summary-label">品种</text>
              <text class="plan-summary-value">{{planScenario.userVariety || '未填写'}}</text>
            </view>
            <view class="plan-summary-row">
              <text class="plan-summary-label">密度</text>
              <text class="plan-summary-value">{{planScenario.userDensity || '未填写'}} 株/亩</text>
            </view>
            <view class="plan-summary-ref" wx:if="{{planScenario.targetYield}}">
              <text>📈 推荐目标产量：{{planScenario.targetYield}} kg/亩</text>
            </view>
            <view class="plan-summary-note" wx:if="{{planScenario.specialNotes}}">
              <text>💡 {{planScenario.specialNotes}}</text>
            </view>
          </view>
        </view>

        <!-- 旧农场缺少条件字段的提示 -->
        <view class="plan-missing" wx:if="{{!loadingDetail && !planScenario && hasFarms}}">
          <text class="plan-missing-icon">⚠️</text>
          <text class="plan-missing-title">农场信息不完整</text>
          <text class="plan-missing-body">当前农场缺少积温、土地类型或灌溉方式，无法生成种植方案。请删除后重新创建农场，或添加新农场完善信息。</text>
          <view class="plan-missing-action" bindtap="addNewFarm">
            <text>添加新农场 →</text>
          </view>
        </view>

        <view class="stage-description" wx:if="{{!loadingDetail}}">
          <text class="stage-desc-title">📷 拍摄要求</text>
          <text class="stage-desc-body">①本人田间作业自拍（手持农资入镜）；②肥料/农药包装清晰照。须当日现场拍摄，禁止相册选取旧图。</text>
        </view>
        <view class="stage-actions">
          <view class="btn-upload {{nodeStatus === 'readable' || uploadRemaining <= 0 ? 'btn-disabled' : ''}}" bindtap="onUploadMedia" data-type="image">
            <text class="btn-upload-icon">📷</text>
            <text class="btn-upload-text">上传照片 {{uploadCount}}/2</text>
          </view>
          <view class="btn-video {{nodeStatus === 'readable' || uploadRemaining <= 0 ? 'btn-disabled' : ''}}" bindtap="onUploadMedia" data-type="video">
            <text class="btn-video-icon">🎥</text>
            <text class="btn-video-text">上传视频 {{uploadCount}}/2</text>
          </view>
        </view>
        <view class="subscribe-row">
          <view class="btn-subscribe" bindtap="requestSubscribe">
            <text class="btn-subscribe-icon">🔔</text>
            <text class="btn-subscribe-text">{{hasSubscribed ? '再次订阅下次提醒' : '订阅施肥提醒'}}</text>
          </view>
        </view>
      </view>

      <!-- Right Column: Tasks & Insight -->
      <view class="side-column">
        <!-- Tasks Card -->
        <view class="tasks-card">
          <view class="tasks-header">
            <text class="tasks-icon">☑️</text>
            <text class="tasks-title">操作清单</text>
          </view>
          <view class="task-list" wx:if="{{!loadingDetail}}">
            <view 
              class="task-item {{item.completed ? 'completed-task' : ''}}" 
              wx:for="{{tasks}}" 
              wx:key="id"
              bindtap="toggleTask"
              data-id="{{item.id}}"
            >
              <view class="task-checkbox {{item.completed ? 'checked' : ''}}">
                <text class="task-checkmark" wx:if="{{item.completed}}">✓</text>
              </view>
              <view class="task-content">
                <text class="task-name {{item.completed ? 'completed-name' : ''}}">{{item.name}}</text>
                <text class="task-meta">{{item.meta}}</text>
              </view>
            </view>
          </view>
          <view class="task-loading" wx:if="{{loadingDetail}}">
            <text>加载任务中...</text>
          </view>
          <!-- Check-in Button -->
          <view class="checkin-action">
            <view 
              class="btn-checkin {{checkInBtnClass}}" 
              bindtap="onCheckIn"
            >
              <text class="btn-checkin-icon">{{checkInBtnIcon}}</text>
              <text class="btn-checkin-text">{{checkInBtnText}}</text>
            </view>
          </view>
        </view>

        <!-- 本次打卡注意事项 -->
        <view class="insight-card" wx:if="{{currentNode.reason}}">
          <view class="insight-header">
            <text class="insight-icon">⚠️</text>
            <text class="insight-label">本次打卡注意事项</text>
          </view>
          <text class="insight-text">{{currentNode.reason}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Bottom Navigation -->
  <view class="bottom-nav glass-panel" wx:if="{{!loading && hasFarms}}">
    <view class="nav-item" bindtap="navigateTo" data-page="checkin">
      <text class="nav-icon">🚜</text>
      <text class="nav-label active-label">打卡</text>
    </view>
    <view class="nav-item" bindtap="navigateTo" data-page="logs">
      <text class="nav-icon">⏱</text>
      <text class="nav-label">记录</text>
    </view>
    <view class="nav-item" bindtap="navigateTo" data-page="ai">
      <text class="nav-icon">🤖</text>
      <text class="nav-label">AI助手</text>
    </view>
  </view>
</view>
