/* AI 助手页面样式 - 参考 ai/screen.png */
.container {
  min-height: 100vh;
  background-color: var(--surface);
  display: flex;
  flex-direction: column;
  padding-bottom: 320rpx;
}

/* 顶部应用栏 */
.app-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 48rpx 32rpx 24rpx;
  background-color: var(--surface);
  position: sticky;
  top: 0;
  z-index: 40;
}

.app-bar-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  background-color: var(--surface-container-high);
  box-shadow: 0 8rpx 32rpx rgba(21, 66, 18, 0.04);
}

.avatar-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.app-title {
  font-size: 32rpx;
  font-weight: 900;
  color: var(--primary);
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.app-bar-right {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background-color: var(--surface-container-lowest);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(21, 66, 18, 0.04);
}

.notification-icon {
  font-size: 40rpx;
}

/* 内容区 */
.content {
  flex: 1;
  padding: 32rpx;
  overflow-y: auto;
}

/* 页面标题 */
.page-header {
  margin-bottom: 48rpx;
  padding-left: 16rpx;
}

.page-title {
  display: block;
  font-size: 56rpx;
  font-weight: 800;
  color: var(--primary);
  line-height: 1.15;
  margin-bottom: 16rpx;
}

.page-subtitle {
  display: block;
  font-size: 30rpx;
  color: var(--on-surface-variant);
  max-width: 80%;
}

/* 聊天区域 */
.chat-area {
  display: flex;
  flex-direction: column;
  gap: 48rpx;
  padding: 0 16rpx;
}

/* 消息 */
.message {
  display: flex;
  gap: 24rpx;
}

.ai-message {
  margin-right: 96rpx;
}

.user-message {
  margin-left: 96rpx;
  justify-content: flex-end;
}

.ai-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: var(--primary-container);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 8rpx;
  box-shadow: 0 8rpx 32rpx rgba(21, 66, 18, 0.08);
}

.ai-avatar-icon {
  font-size: 36rpx;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  margin-top: 8rpx;
  box-shadow: 0 8rpx 32rpx rgba(21, 66, 18, 0.04);
}

.user-avatar-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.avatar-fallback,
.user-avatar-fallback {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background-color: #e8e8e8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.message-bubble {
  padding: 32rpx 40rpx;
  max-width: 100%;
}

.ai-bubble {
  background-color: var(--primary-container);
  border-radius: 32rpx;
  border-top-left-radius: 8rpx;
  box-shadow: 0 8rpx 32rpx rgba(21, 66, 18, 0.06);
  backdrop-filter: blur(10rpx);
}

.user-bubble {
  background-color: var(--surface-container-lowest);
  border-radius: 32rpx;
  border-top-right-radius: 8rpx;
  box-shadow: 0 8rpx 32rpx rgba(21, 66, 18, 0.04);
}

.message-text {
  font-size: 30rpx;
  line-height: 1.6;
}

.ai-text {
  color: var(--on-primary);
}

.user-text {
  color: var(--on-surface);
}

.message-chips {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.chip {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 24rpx;
  border-radius: 9999rpx;
}

.chip-text {
  font-size: 22rpx;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 4rpx;
}

.chip-primary {
  background-color: var(--primary-fixed);
}

.chip-primary .chip-text {
  color: var(--on-primary-fixed);
}

.chip-secondary {
  background-color: var(--secondary-fixed);
}

.chip-secondary .chip-text {
  color: var(--on-secondary-fixed);
}

/* 输入区域 */
.input-area {
  position: fixed;
  bottom: 160rpx;
  left: 0;
  right: 0;
  padding: 0 32rpx;
  z-index: 30;
}

.suggestions-scroll {
  margin-bottom: 24rpx;
}

.suggestions {
  display: flex;
  gap: 24rpx;
  min-width: max-content;
  padding-bottom: 16rpx;
}

.suggestion-chip {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background-color: var(--surface-container-lowest);
  border-radius: 9999rpx;
  padding: 20rpx 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(21, 66, 18, 0.05);
  border: 1rpx solid rgba(194, 201, 187, 0.15);
  flex-shrink: 0;
}

.suggestion-icon {
  font-size: 28rpx;
}

.suggestion-text {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--primary);
}

.input-box {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background-color: var(--surface-container-lowest);
  border-radius: 24rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 12rpx 48rpx rgba(21, 66, 18, 0.08);
}

.mic-icon {
  font-size: 36rpx;
  padding: 16rpx;
  color: var(--on-surface-variant);
}

.chat-input {
  flex: 1;
  font-size: 30rpx;
  color: var(--on-surface);
  background: transparent;
}

.input-placeholder {
  color: var(--outline);
}

.send-btn {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, var(--secondary), var(--secondary-fixed-dim));
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(55, 107, 16, 0.2);
}

.send-icon {
  font-size: 32rpx;
  color: var(--on-secondary);
}

/* 底部导航 */
.bottom-nav {
  position: fixed;
  bottom: 48rpx;
  left: 5%;
  width: 90%;
  max-width: 640rpx;
  border-radius: 9999rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(21, 66, 18, 0.08);
  z-index: 50;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 32rpx;
  border-radius: 9999rpx;
  opacity: 0.6;
}

.active-nav-item {
  background-color: var(--primary-container);
  opacity: 1;
}

.nav-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.nav-label {
  font-size: 20rpx;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 4rpx;
  color: var(--primary);
}

.active-nav-label {
  color: var(--secondary-container);
}
/* Steps 思考过程 */
.steps-toggle {
  margin-top: 12rpx;
  padding: 8rpx 0;
}
.steps-toggle-text {
  font-size: 22rpx;
  color: var(--primary);
  opacity: 0.7;
}
.steps-panel {
  margin-top: 8rpx;
  padding: 16rpx;
  background: rgba(0, 0, 0, 0.03);
  border-radius: 12rpx;
  border-left: 4rpx solid var(--primary);
}
.step-item {
  margin-bottom: 12rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}
.step-item:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}
.step-role {
  display: block;
  font-size: 20rpx;
  font-weight: 700;
  color: var(--primary);
  margin-bottom: 4rpx;
  text-transform: uppercase;
}
.step-content {
  display: block;
  font-size: 22rpx;
  color: var(--on-surface-variant);
  line-height: 1.5;
  word-break: break-all;
}
.step-meta {
  display: block;
  font-size: 18rpx;
  color: var(--outline);
  margin-top: 4rpx;
}
