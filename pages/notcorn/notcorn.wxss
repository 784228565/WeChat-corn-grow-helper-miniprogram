/* Not Growing Corn Page Styles - Matching _4/screen.png */
.container {
  min-height: 100vh;
  background-color: var(--surface);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.card {
  width: 100%;
  max-width: 640rpx;
  background-color: var(--surface-container-lowest);
  border-radius: 32rpx;
  padding: 80rpx 64rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 48rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(27, 28, 26, 0.06);
}

.card-decoration {
  position: absolute;
  top: -128rpx;
  right: -128rpx;
  width: 384rpx;
  height: 384rpx;
  background-color: var(--primary-fixed);
  border-radius: 50%;
  opacity: 0.2;
  filter: blur(80rpx);
  pointer-events: none;
}

.card-icon-wrapper {
  width: 128rpx;
  height: 128rpx;
  background-color: var(--surface-container-low);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.card-icon {
  font-size: 64rpx;
}

.card-content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  position: relative;
  z-index: 1;
  width: 100%;
  padding-left: 16rpx;
}

.card-title {
  font-size: 52rpx;
  font-weight: 700;
  color: var(--primary);
  line-height: 1.2;
}

.card-description {
  font-size: 30rpx;
  color: var(--on-surface-variant);
  line-height: 1.6;
}

.card-action {
  width: 100%;
  margin-top: 16rpx;
  position: relative;
  z-index: 1;
}

.btn-close {
  width: 100%;
  background-color: var(--secondary);
  color: var(--on-secondary);
  border-radius: 32rpx;
  padding: 32rpx;
  font-size: 32rpx;
  font-weight: 700;
  border: none;
  letter-spacing: 2rpx;
}

.btn-close:active {
  opacity: 0.9;
}
